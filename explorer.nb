Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", " ", "@", " ", "solver"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"solver", "[", 
    RowBox[{"accuracy_", ":", "25"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"omegas", ",", "eqs", ",", "sol"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Solve", " ", "for", " ", "Lorentz", " ", "params"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"omegas", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Omega]tx", "[", "i", "]"}], ",", "0"}], "}"}], ",", 
             
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Omega]ty", "[", "i", "]"}], ",", "0"}], "}"}], ",", 
             
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Omega]xy", "[", "i", "]"}], ",", "0"}], "}"}]}], 
            "\[IndentingNewLine]", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "2", ",", "\[ScriptCapitalN]"}], "}"}]}], "]"}],
          ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"eqs", "=", "EoM"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{"FindRoot", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"eqs", "\[Equal]", "0"}], "]"}], ",", "\[IndentingNewLine]",
          "omegas", ",", "\[IndentingNewLine]", 
         RowBox[{"AccuracyGoal", "\[Rule]", "accuracy"}]}], 
        "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{"gaugeFix", ",", "sol"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
