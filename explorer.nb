 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"detRow", "[", 
     RowBox[{"name_", ",", "mat_", ",", "sol_", ",", "tol_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"(*", "d", "*)"}], 
       RowBox[{"d", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"N", "@", 
          RowBox[{"Det", "[", 
           RowBox[{"mat", "/.", " ", "sol"}], "]"}]}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<Object\>\"", "->", "name"}], ",", "\[IndentingNewLine]", 
        
        RowBox[{"\"\<Det\>\"", "->", "d"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Finite\>\"", "->", 
         RowBox[{"FreeQ", "[", 
          RowBox[{"d", ",", 
           RowBox[{"Indeterminate", "|", "Infinity", "|", 
            RowBox[{"DirectedInfinity", "[", "_", "]"}], "|", 
            "ComplexInfinity"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Real\>\"", "->", 
         RowBox[{
          RowBox[{"RealValuedNumericQ", "[", "d", "]"}], "&&", 
          RowBox[{
           RowBox[{"Im", "[", "d", "]"}], "==", "0"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Positive\>\"", "->", 
         RowBox[{
          RowBox[{"Re", "[", "d", "]"}], ">", "tol"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Sign\>\"", "->", 
         RowBox[{"Quiet", "@", 
          RowBox[{"Check", "[", 
           RowBox[{
            RowBox[{"Sign", "[", "d", "]"}], ",", 
            RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], 
           "]"}]}]}]}], "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]",
      "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
